{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pixel Driller metadata package",
  "type": "object",
  "required": ["$schema", "datasets"],
  "properties": {
    "$schema": {
      "const": "./metadata.schema.json"
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          {
            "$ref": "./rdls-v1_0-dataset.schema.json"
          },
          {
            "type": "object",
            "properties": {
              "resources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "dialect": {
                      "$ref": "./datapackage-tabledialect.schema.json",
                      "title": "Resource contents dialect"
                    },
                    "schema": {
                      "$ref": "./datapackage-tableschema.schema.json",
                      "title": "Resource contents schema"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
